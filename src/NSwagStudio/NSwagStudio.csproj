<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyTitle>NSwagStudio</AssemblyTitle>
    <Product>NSwagStudio</Product>
    <ApplicationIcon>ApplicationIcon.ico</ApplicationIcon>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <NoWarn>$(NoWarn);CS0618</NoWarn>
    <AnalysisLevel>none</AnalysisLevel>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <Nullable>enable</Nullable>
    <SignAssembly>false</SignAssembly>
    <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="nswag.cmd" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="ApplicationIcon.ico" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NSwag.Commands\NSwag.Commands.csproj" />
    <ProjectReference Include="..\NSwag.Generation.WebApi\NSwag.Generation.WebApi.csproj" />
    <ProjectReference Include="..\NSwag.ConsoleCore\NSwag.ConsoleCore.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- Copy NSwag.ConsoleCore runtime tools into Net80/Net90/Net100 subdirectories on publish -->
  <Target Name="IncludeConsoleCoreRuntimes" AfterTargets="Publish">
    <PropertyGroup>
      <_ConsoleCoreProject>$(MSBuildThisFileDirectory)..\NSwag.ConsoleCore\NSwag.ConsoleCore.csproj</_ConsoleCoreProject>
    </PropertyGroup>

    <Exec Command="dotnet publish &quot;$(_ConsoleCoreProject)&quot; -c $(Configuration) -f net8.0 -o &quot;$(PublishDir)Net80&quot; --no-restore" />
    <Exec Command="dotnet publish &quot;$(_ConsoleCoreProject)&quot; -c $(Configuration) -f net9.0 -o &quot;$(PublishDir)Net90&quot; --no-restore" />
    <Exec Command="dotnet publish &quot;$(_ConsoleCoreProject)&quot; -c $(Configuration) -f net10.0 -o &quot;$(PublishDir)Net100&quot; --no-restore" />
  </Target>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="Avalonia.AvaloniaEdit" />
    <PackageReference Include="AvaloniaEdit.TextMate" />
    <PackageReference Include="TextMateSharp.Grammars" />
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="MessageBox.Avalonia" />
    <PackageReference Include="Avalonia.Diagnostics" Condition="'$(Configuration)' == 'Debug'" />
  </ItemGroup>
</Project>
