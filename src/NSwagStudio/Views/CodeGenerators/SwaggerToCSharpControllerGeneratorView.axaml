<UserControl x:Class="NSwagStudio.Views.CodeGenerators.SwaggerToCSharpControllerGeneratorView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:NSwagStudio.Converters"
             xmlns:viewModels="using:NSwagStudio.ViewModels.CodeGenerators"
             xmlns:controls="using:NSwagStudio.Controls"
             xmlns:views="using:NSwagStudio.Views.CodeGenerators.Views">

    <UserControl.Resources>
        <viewModels:SwaggerToCSharpControllerGeneratorViewModel x:Key="ViewModel" />
        <converters:VisibilityConverter x:Key="VisibilityConverter" />
        <converters:NotConverter x:Key="NotConverter" />
        <converters:NumberAdditionConverter x:Key="NumberAdditionConverter" />
        <converters:StringArrayConverter x:Key="StringArrayConverter" />
    </UserControl.Resources>

    <TabControl Margin="8" Name="TabControl" DataContext="{StaticResource ViewModel}">
        <TabItem Header="Settings">
            <ScrollViewer x:Name="ScrollViewer" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8,8,8,0">
                    <TextBlock Text="CSharp Controller Settings" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />

                    <TextBlock Text="Namespace" FontWeight="Bold" Margin="0,0,0,6" />
                    <TextBox Text="{Binding Command.Namespace, Mode=TwoWay}" Margin="0,0,0,12" />

                    <TextBlock Text="Additional Namespace Usages (comma separated)" FontWeight="Bold" Margin="0,0,0,6" />
                    <TextBox Text="{Binding Command.AdditionalNamespaceUsages, Mode=TwoWay, Converter={StaticResource StringArrayConverter}, ConverterParameter=','}" Margin="0,0,0,12" />

                    <HeaderedContentControl Header="Controller" Margin="0,0,0,12">
                        <StackPanel Margin="4,8,4,-8">
                            <TextBlock Text="Controller Style" FontWeight="Bold" Margin="0,0,0,6" />
                            <ComboBox SelectedItem="{Binding Command.ControllerStyle, Mode=TwoWay}" ToolTip.Tip="ControllerStyle" ItemsSource="{Binding ControllerStyles}" Margin="0,0,0,12" />
                            <TextBlock Text="Controller Target" FontWeight="Bold" Margin="0,0,0,6" />
                            <ComboBox SelectedItem="{Binding Command.ControllerTarget, Mode=TwoWay}" ToolTip.Tip="ControllerTarget" ItemsSource="{Binding ControllerTargets}" Margin="0,0,0,12" />
                            <CheckBox IsChecked="{Binding Command.UseActionResultType, Mode=TwoWay}" ToolTip.Tip="UseActionResultType" Content="Use ASP.Net Core (2.1) ActionResult type as return type" Margin="0,0,0,12" />
                            <CheckBox IsChecked="{Binding Command.UseCancellationToken, Mode=TwoWay}" ToolTip.Tip="UseCancellationToken" Content="Add cancellation token to controller methods" Margin="0,0,0,12" />
                            <CheckBox IsChecked="{Binding Command.GenerateModelValidationAttributes, Mode=TwoWay}" ToolTip.Tip="GenerateModelValidationAttributes" Content="Add model validation attributes" Margin="0,0,0,12" />
                            <CheckBox IsChecked="{Binding Command.WrapResponses, Mode=TwoWay}" ToolTip.Tip="WrapResponses" Content="Wrap success responses to allow full response access" Margin="0,0,0,12" />
                            <CheckBox IsChecked="{Binding Command.GenerateOptionalParameters, Mode=TwoWay}" ToolTip.Tip="GenerateOptionalParameters" Content="Generate optional parameters" Margin="0,0,0,12" />

                            <TextBlock Text="Excluded Parameter Names (comma separated)." FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBox ToolTip.Tip="ExcludedParameterNames" Text="{Binding Command.ExcludedParameterNames, Mode=TwoWay, Converter={StaticResource StringArrayConverter}, ConverterParameter=','}" Margin="0,0,0,12" />

                            <TextBlock Text="Route Naming Strategy" FontWeight="Bold" Margin="0,0,0,6" />
                            <ComboBox SelectedItem="{Binding Command.RouteNamingStrategy, Mode=TwoWay}" ToolTip.Tip="RouteNamingStrategy" ItemsSource="{Binding RouteNamingStrategies}" Margin="0,0,0,12" />

                            <StackPanel IsVisible="{Binding Command.WrapResponses}">
                                <TextBlock Text="Methods where responses are wrapped (empty for all, 'ControllerName.MethodName', comma separated)" FontWeight="Bold" Margin="0,0,0,6" />
                                <TextBox ToolTip.Tip="WrapResponseMethods" Text="{Binding Command.WrapResponseMethods, Mode=TwoWay, Converter={StaticResource StringArrayConverter}, ConverterParameter=','}" Margin="0,0,0,12" />
                                <CheckBox IsChecked="{Binding Command.GenerateResponseClasses, Mode=TwoWay}" Content="Generate response classes (when disabled, response classes must be imported)" Margin="0,0,0,6" />
                                <StackPanel IsVisible="{Binding Command.GenerateResponseClasses}">
                                    <TextBlock Text="Response class name (may contain the '{controller}' placeholder)" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.ResponseClass, Mode=TwoWay}" Margin="0,0,0,12" />
                                </StackPanel>
                            </StackPanel>

                            <HeaderedContentControl Header="Web API Controller" Margin="0,0,0,12">
                                <StackPanel Margin="4,8,4,-8">
                                    <TextBlock Text="BasePath override (RoutePrefix)" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.BasePath, Mode=TwoWay}" Margin="0,0,0,12" />
                                    <TextBlock Text="Controller Class Name" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.ClassName, Mode=TwoWay}" Margin="0,0,0,12" />
                                    <TextBlock Text="Controller Base Class Name (optional, use 'Microsoft.AspNetCore.Mvc.Controller' for ASP.NET Core)" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.ControllerBaseClass, Mode=TwoWay}" Margin="0,0,0,12" />
                                    <TextBlock Text="Operation Generation Mode" FontWeight="Bold" Margin="0,0,0,6" />
                                    <ComboBox SelectedItem="{Binding Command.OperationGenerationMode, Mode=TwoWay}" ItemsSource="{Binding OperationGenerationModes}" Margin="0,0,0,12" />
                                    <TextBlock Text="Included Operation IDs (comma separated)." FontWeight="Bold" Margin="0,0,0,12" />
                                    <TextBox ToolTip.Tip="IncludedOperationIds" Text="{Binding Command.IncludedOperationIds, Mode=TwoWay, Converter={StaticResource StringArrayConverter}, ConverterParameter=','}" Margin="0,0,0,12" />
                                    <TextBlock Text="Excluded Operation IDs (comma separated)." FontWeight="Bold" Margin="0,0,0,12" />
                                    <TextBox ToolTip.Tip="ExcludedOperationIds" Text="{Binding Command.ExcludedOperationIds, Mode=TwoWay, Converter={StaticResource StringArrayConverter}, ConverterParameter=','}" Margin="0,0,0,12" />
                                </StackPanel>
                            </HeaderedContentControl>

                            <HeaderedContentControl Header="Parameter Types" Margin="0,0,0,12">
                                <StackPanel Margin="4,8,4,-8">
                                    <TextBlock Text="Generic Array Type" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.ParameterArrayType, Mode=TwoWay}" ToolTip.Tip="ParameterArrayType" Margin="0,0,0,12" />
                                    <TextBlock Text="Generic Dictionary Type" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.ParameterDictionaryType, Mode=TwoWay}" ToolTip.Tip="ParameterDictionaryType" Margin="0,0,0,12" />
                                </StackPanel>
                            </HeaderedContentControl>

                            <HeaderedContentControl Header="Response Types" Margin="0,0,0,12">
                                <StackPanel Margin="4,8,4,-8">
                                    <TextBlock Text="Generic Array Type" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.ResponseArrayType, Mode=TwoWay}" ToolTip.Tip="ResponseArrayType" Margin="0,0,0,12" />
                                    <TextBlock Text="Generic Dictionary Type" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Command.ResponseDictionaryType, Mode=TwoWay}" ToolTip.Tip="ResponseDictionaryType" Margin="0,0,0,12" />
                                </StackPanel>
                            </HeaderedContentControl>
                        </StackPanel>
                    </HeaderedContentControl>

                    <views:CSharpSettingsView />

                    <HeaderedContentControl Header="Templating" Margin="0,0,0,12">
                        <StackPanel Margin="4,8,4,-8">
                            <TextBlock Text="Template directory" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBox Text="{Binding Command.TemplateDirectory, Mode=TwoWay}" ToolTip.Tip="TemplateDirectory" Margin="0,0,0,12" />
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Header="Output" Margin="0,0,0,12">
                        <StackPanel Margin="4,8,4,-8">
                            <TextBlock Text="Output file path (empty: no file output)" FontWeight="Bold" Margin="0,0,0,6" />
                            <controls:FileSavePicker DefaultExtension=".cs" Filter="CSharp Files (.cs)|*.cs" FilePath="{Binding Command.OutputFilePath, Mode=TwoWay}" Margin="0,0,0,12" />
                            <TextBlock Margin="0,0,0,6" Text="New Line Behavior" TextWrapping="Wrap" FontWeight="Bold" />
                            <ComboBox SelectedItem="{Binding Command.NewLineBehavior, Mode=TwoWay}" ItemsSource="{Binding NewLineBehaviors}" Margin="0,0,0,12" />
                        </StackPanel>
                    </HeaderedContentControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Output">
            <Border Margin="-2">
                <controls:BindableTextEditor
                    Text="{Binding ClientCode, Mode=TwoWay}"
                    SyntaxHighlighting="csharp"
                    IsReadOnly="True"
                    ShowLineNumbers="True" />
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
